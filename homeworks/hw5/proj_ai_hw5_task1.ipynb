      "source": [
        "**Dataset**: Intel Image Classification \\\n",
        "This dataset contains approximately 25,000 images across six classes, buildings, forest, glacier, mountain, sea, and street. The dataset is split into training and testing sets.\n",
        "\n",
        "https://www.kaggle.com/datasets/puneet6060/intel-image-classification"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "8IdmQzpKbjbu"
      },
      "source": [
        "<h1> Task 1"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "-KvlAFP3bn2K"
      },
      "source": [
        "Part 1"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "WLLWBIdUbIfm"
      },
      "outputs": [],
      "source": [
        "import tensorflow as tf\n",
        "from tensorflow.keras.preprocessing import image_dataset_from_directory\n",
        "from tensorflow.keras import layers, models\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# unzip file\n",
        "!unzip \"archive (3).zip\"\n",
        "\n",
        "# paths to folders\n",
        "train_dir = \"/content/seg_train/seg_train\"\n",
        "test_dir = \"/content/seg_test/seg_test\"\n",
        "\n",
        "IMG_SIZE = (150, 150)\n",
        "BATCH_SIZE = 32\n",
        "\n",
        "# load training data\n",
        "train_data = image_dataset_from_directory(\n",
        "  train_dir,\n",
        "  validation_split=0.2,\n",
        "  subset=\"training\",\n",
        "  seed=123,\n",
        "  image_size=IMG_SIZE,\n",
        "  batch_size=BATCH_SIZE\n",
        ")\n",
        "\n",
        "# validation data\n",
        "val_data = image_dataset_from_directory(\n",
        "  train_dir,\n",
        "  validation_split=0.2,\n",
        "  subset=\"validation\",\n",
        "  seed=123,\n",
        "  image_size=IMG_SIZE,\n",
        "  batch_size=BATCH_SIZE\n",
        ")\n",
        "\n",
        "# test data\n",
        "test_data = image_dataset_from_directory(\n",
        "  test_dir,\n",
        "  image_size=IMG_SIZE,\n",
        "  batch_size=BATCH_SIZE\n",
        ")\n",
        "\n",
        "class_names = train_data.class_names\n",
        "num_classes = len(class_names)"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# visualize dataset\n",
        "plt.figure(figsize=(8,8))\n",
        "\n",
        "# one batch of images\n",
        "for images, labels in train_data.take(1):\n",
        "  # first 9 images in grid\n",
        "  for i in range(9):\n",
        "    plt.subplot(3,3,i+1)\n",
        "    plt.imshow(images[i].numpy().astype(\"uint8\")) # convert to displayable format\n",
        "    plt.title(class_names[labels[i]])\n",
        "    plt.axis(\"off\")\n",
        "\n",
        "plt.show()"
      ],
      "metadata": {
        "id": "KAstBN-Svm7u",
