        "def plot_history(history, title):\n",
        "  plt.plot(history.history['accuracy'])\n",
        "  plt.plot(history.history['val_accuracy'])\n",
        "  plt.title(title)\n",
        "  plt.xlabel('Epoch')\n",
        "  plt.ylabel('Accuracy')\n",
        "  plt.legend(['Train', 'Validation'])\n",
        "  plt.show()\n",
        "\n",
        "plot_history(history, \"CNN Accuracy\")\n",
