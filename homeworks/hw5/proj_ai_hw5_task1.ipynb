      "source": [
        "# data augmentation - increase dataset diversity and reduce overfitting\n",
        "def augment(x, y):\n",
        "  x = tf.image.random_flip_left_right(x)\n",
        "  x = tf.image.random_brightness(x, 0.2)\n",
        "  x = tf.image.random_contrast(x, 0.8, 1.2)\n",
        "\n",
        "  # approximate zoom\n",
        "  x = tf.image.central_crop(x, central_fraction=0.9)  # crop central 90%\n",
        "  x = tf.image.resize(x, [150, 150])  # back to original size\n",
        "\n",
        "  x = tf.cast(x, tf.float32) / 255.0\n",
        "  return x, y\n",
        "\n",
        "aug_train_data = train_data.map(augment)\n",
        "val_data = val_data.map(lambda x, y: (tf.cast(x, tf.float32)/255.0, y))\n",
        "test_data = test_data.map(lambda x, y: (tf.cast(x, tf.float32)/255.0, y))"
      ]
